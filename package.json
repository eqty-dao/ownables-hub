{
  "name": "@ownables/hub",
  "version": "0.0.0",
  "description": "Ownables Hub",
  "author": "Ownables",
  "type": "module",
  "packageManager": "yarn@4.15.0",
  "engines": {
    "node": ">=24"
  },
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist tsconfig.build.tsbuildinfo",
    "build": "tsc -p tsconfig.build.json --incremental false",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node --preserve-symlinks dist/main.js",
    "start:dev": "bash ./scripts/start-dev.sh",
    "start:debug": "NODE_INSPECT=--inspect bash ./scripts/start-dev.sh",
    "start:prod": "node --preserve-symlinks dist/main.js",
    "indexer:run": "node --preserve-symlinks dist/indexer/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest --detectOpenHandles",
    "verify:core-compat": "yarn node scripts/verify-core-compat.mjs",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "release": "semantic-release",
    "db:start": "bash ./scripts/db-start.sh",
    "db:migrate:create": "node-pg-migrate create -m migrations",
    "db:migrate:up": "node-pg-migrate up -m migrations",
    "db:migrate:down": "node-pg-migrate down -m migrations",
    "verify:hub-replay-boundary": "yarn node scripts/verify-hub-replay-boundary.mjs"
  },
  "dependencies": {
    "@babel/core": "^7.29.7",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "@ownables/core": "file:/tmp/eqty-class-based-service-boundaries/ownables-js-843e957/ownables-core-0.9.0.tgz",
    "@ownables/platform-node": "file:/tmp/eqty-class-based-service-boundaries/ownables-js-843e957/ownables-platform-node-0.9.0.tgz",
    "any-bucket": "^0.1.6",
    "axios": "^1.16.1",
    "babel-plugin-remove-import-export": "^1.1.1",
    "bs58": "^6.0.0",
    "eqty-core": "^1.0.2",
    "ethers": "^6.16.0",
    "jszip": "^3.10.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2"
  },
  "resolutions": {
    "@ownables/core": "file:/tmp/eqty-class-based-service-boundaries/ownables-js-843e957/ownables-core-0.9.0.tgz"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "node-pg-migrate": "^8.0.3",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "transformIgnorePatterns": []
  }
}
